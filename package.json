{
  "name": "wjftp",
  "version": "1.0.0",
  "description": "WJFTP - CDN Upload Manager for SK-CDN and Naver Cloud",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "tsc -p tsconfig.json --watch",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --win --mac",
    "start": "cross-env NODE_ENV=development electron ."
  },
  "build": {
    "appId": "com.wjthinkbig.wjftp",
    "productName": "WJFTP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "WJFTP",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WJFTP",
      "allowElevation": true
    },
    "extraResources": []
  },
  "keywords": [
    "cdn",
    "ftp",
    "upload",
    "sk-cdn",
    "naver-cloud"
  ],
  "author": "WJTHINKBIG",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "basic-ftp": "^5.0.5",
    "electron-store": "^10.0.1",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^6.0.0",
    "antd": "^6.3.2",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "i18next": "^25.8.18",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^8.0.0"
  }
}
